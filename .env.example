# MiMo API 配置 (Anthropic 兼容格式)
# 复制此文件为 .env 并填入你的真实密钥

# API 密钥（必填）
MIMO_API_KEY=your-api-key-here

# API 地址（默认值）
MIMO_API_BASE=https://token-plan-cn.xiaomimimo.com/anthropic

# 模型名称（mimo-v2-flash 或 mimo-v2.5-pro）
MIMO_MODEL=mimo-v2-flash

# Google Analytics ID（上线后填入）
# GOOGLE_ANALYTICS=G-XXXXXXXXXX

# Google AdSense 发布商 ID（申请通过后填入）
# ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX

# 百度统计 ID（上线后填入）
# BAIDU_ANALYTICS=your-baidu-analytics-id
